# Django DRF API (server-only — never exposed to the browser)
# v1 contract: http://localhost:8000/api/v1/
# Swagger UI: http://localhost:8000/api/docs/
HMIS_API_URL=http://localhost:8000/api/v1

# Gateway static-asset prefix (production / docker / nginx gateway only).
# Leave unset for direct `npm run dev` on :3000 — setting it without the gateway
# causes ChunkLoadError because chunks are requested from /__hmis_web_new/_next/...
# NEXT_PUBLIC_ASSET_PREFIX=/__hmis_web_new
#
# When using deploy/nginx/gateway.dev.conf on :8080, set both:
# NEXT_PUBLIC_ASSET_PREFIX=/__hmis_web_new
# NEXT_PUBLIC_USE_GATEWAY_ASSET_PREFIX=true
