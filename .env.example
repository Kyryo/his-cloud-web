# Django DRF API (server-only — never exposed to the browser)
# v1 contract: http://localhost:8000/api/v1/
# Swagger UI: http://localhost:8000/api/docs/
HMIS_API_URL=http://localhost:8000/api/v1

# Isolates web-new static assets when routed through the deploy gateway.
NEXT_PUBLIC_ASSET_PREFIX=/__hmis_web_new
